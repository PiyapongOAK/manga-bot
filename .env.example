# ===================================
#  .env — ค่าลับ ห้าม Upload ขึ้น Git!
# ===================================

# Token บอทจาก Discord Developer Portal → Bot → Reset Token
DISCORD_TOKEN=ใส่_TOKEN_ตรงนี้

# Application ID จาก Discord Developer Portal → General Information
CLIENT_ID=ใส่_CLIENT_ID_ตรงนี้

# ID ของ Channel ที่บอทจะส่งแจ้งเตือนเข้า
# วิธีดู: เปิด Discord → Settings → Advanced → Developer Mode ON
#          แล้วคลิกขวาที่ Channel → Copy Channel ID
NEWS_CHANNEL_ID=ใส่_CHANNEL_ID_ตรงนี้
